# Sample environment configuration
# Copy this file to .env and modify the values

# Application base path (relative path from exe to project root)
# Development default: ..\.. (exe in Win32\Debug)
# Production: . (exe alongside templates/www/etc.)
# APP_BASE_PATH=.

# Server configuration
SERVER_PORT=8080

# Database configuration (if using ActiveRecord)
# DB_CONNECTION_DEF_NAME=MyConnection
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=user
# DB_PASSWORD=password

# JWT configuration (if using JWT middleware)
# JWT_SECRET=your-secret-key-change-this-in-production
# JWT_EXPIRES_HOURS=24
