  end;
  lR := TMVCActiveRecord.GetByPK<TRefreshableTracked>(lID);
  try
    lR.Name := 'bob';
    lR.Update;
    Assert.AreEqual('BOB', lR.UpperName.Value, 'Sanity: refresh refetched trigger output');
    Assert.IsFalse(lR.IsChanged,
      'Snapshot must reflect DB-truth values after Update (refresh runs before rehash)');
    Assert.IsFalse(lR.IsChanged('upper_name'));
  finally
    lR.Free;
  end;
end;

