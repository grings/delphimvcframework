    try
      lP.Name  := '';            // violates MVCRequired
      lP.Email := 'bad-email';   // violates MVCEmail
      lP.Age   := 30;
      lP.Insert;
    except
      on E: EMVCStorageValidationException do
        lE := EMVCStorageValidationException(AcquireExceptionObject);
