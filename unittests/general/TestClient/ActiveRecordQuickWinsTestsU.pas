procedure TTestValidationExtras.TestOnStorageValidateAggregatesWithAttributeErrors;
var
  lP: TValidatedWithHook;
  lE: EMVCStorageValidationException;
begin
  lE := nil;
  lP := TValidatedWithHook.Create;
  try
    try
      lP.Name := '';     // Attribute MVCRequired -> 'Name' error
      lP.Flag := 'X';    // OnStorageValidate -> 'Flag' error
      lP.Insert;
    except
      on E: EMVCStorageValidationException do
        lE := EMVCStorageValidationException(AcquireExceptionObject);
    end;
  finally
    lP.Free;
  end;
  try
    Assert.IsNotNull(lE);
    Assert.AreEqual<Integer>(2, lE.ValidationErrors.Count,
      'Attribute and OnStorageValidate errors must be aggregated in one pass');
    Assert.IsTrue(lE.ValidationErrors.ContainsKey('Name'));
    Assert.IsTrue(lE.ValidationErrors.ContainsKey('Flag'));
    Assert.AreEqual('ATTR_REQUIRED', lE.ValidationErrors['Name']);
    Assert.AreEqual('HOOK_ERROR', lE.ValidationErrors['Flag']);
  finally
    lE.Free;
  end;
end;

procedure TTestValidationExtras.TestOnStorageValidateOnlyErrorRaisesAlone;
var
  lP: TValidatedWithHook;
  lE: EMVCStorageValidationException;
begin
  lE := nil;
  lP := TValidatedWithHook.Create;
  try
    try
      lP.Name := 'ok';   // Attribute passes
      lP.Flag := 'X';    // Only the hook fires
      lP.Insert;
    except
      on E: EMVCStorageValidationException do
        lE := EMVCStorageValidationException(AcquireExceptionObject);
    end;
  finally
    lP.Free;
  end;
  try
    Assert.IsNotNull(lE,
      'OnStorageValidate must trigger EMVCStorageValidationException even when no attribute fired');
    Assert.AreEqual<Integer>(1, lE.ValidationErrors.Count);
    Assert.IsTrue(lE.ValidationErrors.ContainsKey('Flag'));
  finally
    lE.Free;
  end;
end;

