procedure TTestAuditInteractions.TestAuditFieldsUntouchedOnFailedValidation;
var
  lE: TAuditableValidated;
  lCreatedAtBefore: TDateTime;
begin
  lE := TAuditableValidated.Create;
  try
    lCreatedAtBefore := lE.CreatedAt;
    Assert.AreEqual(TDateTime(0), lCreatedAtBefore, 'Sanity: CreatedAt = 0 before Insert');
    try
      lE.Name := '';   // MVCRequired fails
      lE.Insert;
      Assert.Fail('Expected EMVCStorageValidationException');
    except
      on E: EMVCStorageValidationException do
        ; // expected
    end;
    Assert.AreEqual(lCreatedAtBefore, lE.CreatedAt,
      'CreatedAt must remain at pre-Insert default when validation fails (FillAuditFields runs AFTER Validate)');
  finally
    lE.Free;
  end;
end;

procedure TTestAuditInteractions.TestAuditUpdatedFieldsAdvanceOnCleanTrackedUpdate;
var
  lE: TOrderCTWithAudit;
  lID: Int64;
  lUpdatedAtBefore: TDateTime;
begin
  lE := TOrderCTWithAudit.Create;
  try
    lE.Total := 100;
    lE.Insert;
    lID := lE.ID;
    lUpdatedAtBefore := lE.UpdatedAt;
  finally
    lE.Free;
  end;
  Sleep(30);
  // Reload and Update WITHOUT changing any user field. With Audit ×
  // ChangeTracking the UPDATE must still touch the row (lock-touch) and
  // FillAuditFields must advance UpdatedAt.
  lE := TMVCActiveRecord.GetByPK<TOrderCTWithAudit>(lID);
  try
    Assert.IsFalse(lE.IsChanged, 'Sanity: just-loaded record is clean');
    lE.Update;
    Assert.IsTrue(lE.UpdatedAt > lUpdatedAtBefore,
      'UpdatedAt must advance even when caller changed nothing — audit fields are added before the dirty SET clause is built');
  finally
    lE.Free;
  end;
end;

