procedure TTestChangeTrackingExtras.TestForefreshFieldRehashedAfterInsert;
var
  lR: TRefreshableTracked;
begin
  // Insert: trigger writes UPPER(name) into upper_name; foRefresh refetches
  // it; ChangeTracking snapshot is rebuilt AFTER refresh — so the refreshed
  // field must NOT appear as changed.
  lR := TRefreshableTracked.Create;
  try
    lR.Name := 'alice';
    lR.Insert;
    Assert.AreEqual('ALICE', lR.UpperName.Value, 'Sanity: refresh worked');
    Assert.IsFalse(lR.IsChanged,
      'Snapshot must reflect DB-truth values after Insert (refresh runs before rehash)');
    Assert.IsFalse(lR.IsChanged('upper_name'),
      'foRefresh column must not be flagged as changed once Insert completes');
  finally
    lR.Free;
  end;
end;

