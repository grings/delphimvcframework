procedure TTestSoftDeleteRQLExtras.TestSelectOneByRQLAutoFiltersDeleted;
var
  lC: TCustomerSDTimestamp;
  lFound: TCustomerSDTimestamp;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Alive';
    lC.Insert;
  finally
    lC.Free;
  end;
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Dead';
    lC.Insert;
    lC.Delete;
  finally
    lC.Free;
  end;
  // Must find Alive
  lFound := TMVCActiveRecord.SelectOneByRQL<TCustomerSDTimestamp>('eq(name,"Alive")', False);
  try
    Assert.IsNotNull(lFound);
    Assert.AreEqual('Alive', lFound.Name);
  finally
    lFound.Free;
  end;
  // Must NOT find Dead — soft-delete predicate is auto-injected
  lFound := TMVCActiveRecord.SelectOneByRQL<TCustomerSDTimestamp>('eq(name,"Dead")', False);
  Assert.IsNull(lFound, 'SelectOneByRQL must filter soft-deleted rows');
end;

procedure TTestSoftDeleteRQLExtras.TestCountAutoFiltersDeleted;
var
  lC: TCustomerSDTimestamp;
  I: Integer;
begin
  for I := 1 to 3 do
  begin
    lC := TCustomerSDTimestamp.Create;
    try
      lC.Name := 'Alive' + IntToStr(I);
      lC.Insert;
    finally
      lC.Free;
    end;
  end;
  for I := 1 to 2 do
  begin
    lC := TCustomerSDTimestamp.Create;
    try
      lC.Name := 'Dead' + IntToStr(I);
      lC.Insert;
      lC.Delete;
    finally
      lC.Free;
    end;
  end;
  Assert.AreEqual<Int64>(3, TMVCActiveRecord.Count<TCustomerSDTimestamp>(),
    'Count must auto-filter soft-deleted rows (3 alive, 2 deleted)');
end;

procedure TTestSoftDeleteRQLExtras.TestCountIncludeSoftDeletedReturnsAll;
var
  lC: TCustomerSDTimestamp;
  I: Integer;
begin
  for I := 1 to 3 do
  begin
    lC := TCustomerSDTimestamp.Create;
    try
      lC.Name := 'Alive' + IntToStr(I);
      lC.Insert;
    finally
      lC.Free;
    end;
  end;
  for I := 1 to 2 do
  begin
    lC := TCustomerSDTimestamp.Create;
    try
      lC.Name := 'Dead' + IntToStr(I);
      lC.Insert;
      lC.Delete;
    finally
      lC.Free;
    end;
  end;
  TMVCActiveRecord.IncludeSoftDeleted(True);
  try
    Assert.AreEqual<Int64>(5, TMVCActiveRecord.Count<TCustomerSDTimestamp>(),
      'IncludeSoftDeleted(True) must bypass the auto-filter on Count too');
  finally
    TMVCActiveRecord.IncludeSoftDeleted(False);
  end;
end;

