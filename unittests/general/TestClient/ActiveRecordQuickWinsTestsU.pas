  // foReadOnly fields.
  // ===================================================================

  [MVCTable('val_extras')]
  TValidatedExtras = class(TMVCActiveRecord)
  strict private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    FID: Int64;
    [MVCTableField('min_name')]
    [MVCMinLength(3)]
    FMinName: string;
    [MVCTableField('exact_code')]
    [MVCLength(5)]
    FExactCode: string;
    [MVCTableField('not_empty_desc')]
    [MVCNotEmpty]
    FNotEmptyDesc: string;
    [MVCTableField('zip')]
    [MVCPattern('^\d{3}$')]
    FZip: string;
    [MVCTableField('status')]
    [MVCIn('A,B,C')]
    FAllowedStatus: string;
    // Plain string + custom message; verifies AMessage parameter is the
    // value surfaced through ValidationErrors.
    [MVCTableField('custom_msg')]
    [MVCRequired('CUSTOM_MSG_TOKEN')]
    FCustomMsg: string;
    // NullableString + MVCRequired; HasValue = False must be reported as
    // missing (Nullable transparency claim).
    [MVCTableField('nullable_req')]
    [MVCRequired]
    FNullableReq: NullableString;
  public
    property ID: Int64 read FID write FID;
    property MinName: string read FMinName write FMinName;
    property ExactCode: string read FExactCode write FExactCode;
    property NotEmptyDesc: string read FNotEmptyDesc write FNotEmptyDesc;
    property Zip: string read FZip write FZip;
    property AllowedStatus: string read FAllowedStatus write FAllowedStatus;
    property CustomMsg: string read FCustomMsg write FCustomMsg;
    property NullableReq: NullableString read FNullableReq write FNullableReq;
  end;

  // Verifies that validators on PK / foAutoGenerated / foReadOnly /
  // foDoNotInsert fields are skipped on Insert. Without the skip rule
  // the framework would reject the default Int64 = 0 PK (MVCRange below)
  // and the default '' foReadOnly column (MVCRequired below). Insert
  // must succeed.
  [MVCTable('val_skip_pk')]
  TValidatedSkipPK = class(TMVCActiveRecord)
  strict private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    [MVCRange(1, 100)]
    FID: Int64;
    [MVCTableField('readonly_col', [foReadOnly])]
    [MVCRequired]
    FReadOnlyCol: string;
    [MVCTableField('regular_name')]
    FRegularName: string;
  public
    property ID: Int64 read FID write FID;
    property ReadOnlyCol: string read FReadOnlyCol write FReadOnlyCol;
    property RegularName: string read FRegularName write FRegularName;
  end;

