procedure TTestValidationExtras.TestValidatorsSkippedOnPKAndReadOnlyOnInsert;
var
  lE: TValidatedSkipPK;
begin
  // PK has [MVCRange(1,100)] but is foAutoGenerated → must skip on Insert.
  // ReadOnly column has [MVCRequired] but default '' → must skip on Insert.
  // If either rule were broken, this Insert would raise.
  lE := TValidatedSkipPK.Create;
  try
    lE.RegularName := 'ok';
    lE.Insert;
    Assert.IsTrue(lE.ID > 0,
