# ============================================================================
# Example 03 - Auto Soft-Delete (timestamp mode)
# The soft_delete_demo table has a deleted_at TIMESTAMP NULL column.
# The generator recognises it by name and type (NullableTDateTime) and emits
# [MVCSoftDeleted]. The column does not receive [MVCRequired] because the
# framework manages it internally via the WHERE deleted_at IS NULL filter.
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex03_softdelete.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
# Default: LowerCase
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
# Default: false
GENERATE_MAPPING=false

# When true, generated classes use a TCustomXxx prefix and are declared
# abstract, allowing you to subclass them and re-generate without overwriting
# your customisations.
# Default: false
CLASS_AS_ABSTRACT=false

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all.
# Default: empty (all tables)
TABLES=soft_delete_demo

# When true, the generator scans each table for a column whose name matches
# one of the SOFT_DELETE_*_NAME lists and emits [MVCSoftDeleted] on it.
# Timestamp mode takes priority over flag mode when both candidates are found.
# Default: true
AUTO_SOFT_DELETE=true

# Comma-separated column names for timestamp-mode soft-delete.
# The column MUST be nullable (NullableTDateTime); a non-nullable datetime
# defaults to 1899-12-30 and would never match the IS NULL filter.
# Default: deleted_at
SOFT_DELETE_TIMESTAMP_NAME=deleted_at

# Comma-separated column names for boolean-flag soft-delete.
# The column must be of type Boolean (not nullable).
# Default: is_deleted,deleted
SOFT_DELETE_FLAG_NAME=is_deleted,deleted

# Table-to-class name override.
MAP_soft_delete_demo=TSoftDeleteDemo
