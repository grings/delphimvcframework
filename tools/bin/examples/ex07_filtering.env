# ============================================================================
# Example 07 - Table filtering with wildcards and exclusions
# TABLES=customers*     -> includes all tables whose name starts with "customers"
# EXCLUDE_TABLES=...    -> excludes specific tables from the matched set
#
# Supported patterns:
#   exact match   customers
#   wildcard      customers*   (* = any string, ? = single character)
#   regex         /^customers_with/
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex07_filtering.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
# Default: LowerCase
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
# Default: false
GENERATE_MAPPING=false

# When true, generated classes use a TCustomXxx prefix and are declared
# abstract, allowing you to subclass them and re-generate without overwriting
# your customisations.
# Default: false
CLASS_AS_ABSTRACT=false

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all tables.
# Default: empty (all tables)
TABLES=customers*

# Comma-separated list of tables to exclude from the generated set.
# Applied after TABLES matching, so it can trim down a wildcard match.
# Default: empty (no exclusions)
EXCLUDE_TABLES=customers with spaces,customers2
