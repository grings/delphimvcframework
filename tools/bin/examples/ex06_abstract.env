# ============================================================================
# Example 06 - Abstract classes (TCustomXxx pattern)
# CLASS_AS_ABSTRACT=true generates classes with a TCustom prefix
# (e.g. TCustomCustomer) that are meant to be subclassed in the project.
# This lets you re-generate the data layer without overwriting customisations
# added in the subclasses.
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex06_abstract.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
# Default: LowerCase
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
# Default: false
GENERATE_MAPPING=true

# When true, generated classes are declared abstract with a TCustomXxx prefix.
# Example: MAP_customers=TCustomer produces "TCustomCustomer = class abstract".
# Subclass TCustomCustomer in your project and add business logic there;
# the next regeneration only touches TCustomCustomer, leaving your subclass intact.
# Default: false
CLASS_AS_ABSTRACT=true

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all.
# Default: empty (all tables)
TABLES=customers,orders,order_details

# Table-to-class name overrides. The TCustom prefix is prepended automatically
# when CLASS_AS_ABSTRACT=true, so TCustomer becomes TCustomCustomer.
MAP_customers=TCustomer
MAP_orders=TOrder
MAP_order_details=TOrderDetail
