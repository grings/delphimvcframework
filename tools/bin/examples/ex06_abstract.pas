unit ex06_abstract;

interface

uses
  MVCFramework.Serializer.Commons,
  MVCFramework.Nullables,
  MVCFramework.ActiveRecord,
  MVCFramework.Validators,
  System.Classes;

type

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers')]
  TCustomCustomer = class abstract(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
    [MVCTableField('last_contact_timestamp')]
    fLastContactTimestamp: NullableTDateTime {dtDateTimeStampOff};
  public
    property ID: NullableInt64 read fID write fID;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
    property LastContactTimestamp: NullableTDateTime {dtDateTimeStampOff} read fLastContactTimestamp write fLastContactTimestamp;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('order_details')]
  TCustomOrderDetail = class abstract(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('id_order')]
    [MVCRequired]
    fIdOrder: Int64;
    [MVCTableField('id_article')]
    [MVCRequired]
    fIdArticle: Int64;
    [MVCTableField('unit_price')]
    [MVCRequired]
    fUnitPrice: Currency;
    [MVCTableField('discount')]
    [MVCRequired]
    fDiscount: Int32;
    [MVCTableField('quantity')]
    [MVCRequired]
    fQuantity: Int32;
    [MVCTableField('description')]
    [MVCRequired]
    [MVCMaxLength(200)]
    fDescription: String;
    [MVCTableField('total')]
    [MVCRequired]
    fTotal: Currency;
  public
    property ID: NullableInt64 read fID write fID;
    property IdOrder: Int64 read fIdOrder write fIdOrder;
    property IdArticle: Int64 read fIdArticle write fIdArticle;
    property UnitPrice: Currency read fUnitPrice write fUnitPrice;
    property Discount: Int32 read fDiscount write fDiscount;
    property Quantity: Int32 read fQuantity write fQuantity;
    property Description: String read fDescription write fDescription;
    property Total: Currency read fTotal write fTotal;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('orders')]
  TCustomOrder = class abstract(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('id_customer')]
    [MVCRequired]
    fIdCustomer: Int32;
    [MVCTableField('order_date')]
    [MVCRequired]
    fOrderDate: TDate;
    [MVCTableField('total')]
    fTotal: NullableCurrency;
  public
    property ID: NullableInt64 read fID write fID;
    property IdCustomer: Int32 read fIdCustomer write fIdCustomer;
    property OrderDate: TDate read fOrderDate write fOrderDate;
    property Total: NullableCurrency read fTotal write fTotal;
  end;

implementation

initialization

ActiveRecordMappingRegistry.AddEntity('customers', TCustomCustomer);
ActiveRecordMappingRegistry.AddEntity('order_details', TCustomOrderDetail);
ActiveRecordMappingRegistry.AddEntity('orders', TCustomOrder);

end.