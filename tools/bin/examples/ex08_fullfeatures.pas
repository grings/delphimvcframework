unit ex08_fullfeatures;

interface

uses
  MVCFramework.Serializer.Commons,
  MVCFramework.Nullables,
  MVCFramework.ActiveRecord,
  MVCFramework.Validators,
  System.Classes;

type

  [MVCNameCase(ncLowerCase)]
  [MVCTable('audit_demo')]
  TAuditDemo = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey])]
    [MVCRequired]
    fID: Int32;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('created_at')]
    [MVCAuditCreatedAt]
    fCreatedAt: NullableTDateTime {dtDateTimeStamp};
    [MVCTableField('updated_at')]
    [MVCAuditUpdatedAt]
    fUpdatedAt: NullableTDateTime {dtDateTimeStamp};
    [MVCTableField('created_by')]
    [MVCAuditCreatedBy]
    fCreatedBy: NullableString;
    [MVCTableField('updated_by')]
    [MVCAuditUpdatedBy]
    fUpdatedBy: NullableString;
  public
    property ID: Int32 read fID write fID;
    property Description: NullableString read fDescription write fDescription;
    property CreatedAt: NullableTDateTime {dtDateTimeStamp} read fCreatedAt write fCreatedAt;
    property UpdatedAt: NullableTDateTime {dtDateTimeStamp} read fUpdatedAt write fUpdatedAt;
    property CreatedBy: NullableString read fCreatedBy write fCreatedBy;
    property UpdatedBy: NullableString read fUpdatedBy write fUpdatedBy;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers')]
  TCustomer = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
    [MVCTableField('last_contact_timestamp')]
    fLastContactTimestamp: NullableTDateTime {dtDateTimeStampOff};
  public
    property ID: NullableInt64 read fID write fID;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
    property LastContactTimestamp: NullableTDateTime {dtDateTimeStampOff} read fLastContactTimestamp write fLastContactTimestamp;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('orders')]
  TOrder = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('id_customer')]
    [MVCRequired]
    fIdCustomer: Int32;
    [MVCTableField('order_date')]
    [MVCRequired]
    fOrderDate: TDate;
    [MVCTableField('total')]
    fTotal: NullableCurrency;
  public
    property ID: NullableInt64 read fID write fID;
    property IdCustomer: Int32 read fIdCustomer write fIdCustomer;
    property OrderDate: TDate read fOrderDate write fOrderDate;
    property Total: NullableCurrency read fTotal write fTotal;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('people')]
  TPerson = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('last_name')]
    [MVCRequired]
    [MVCMaxLength(100)]
    fLastName: String;
    [MVCTableField('first_name')]
    [MVCRequired]
    [MVCMaxLength(100)]
    fFirstName: String;
    [MVCTableField('dob')]
    fDob: NullableTDate;
    [MVCTableField('full_name')]
    [MVCMaxLength(80)]
    fFullName: NullableString;
    [MVCTableField('is_male')]
    fIsMale: NullableBoolean;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('photo')]
    fPhoto: TStream;
    [MVCTableField('person_type')]
    [MVCMaxLength(40)]
    fPersonType: NullableString;
    [MVCTableField('salary')]
    fSalary: NullableCurrency;
    [MVCTableField('annual_bonus')]
    fAnnualBonus: NullableCurrency;
  public
    constructor Create; override;
    destructor Destroy; override;
    property ID: NullableInt64 read fID write fID;
    property LastName: String read fLastName write fLastName;
    property FirstName: String read fFirstName write fFirstName;
    property Dob: NullableTDate read fDob write fDob;
    property FullName: NullableString read fFullName write fFullName;
    property IsMale: NullableBoolean read fIsMale write fIsMale;
    property Note: NullableString read fNote write fNote;
    property Photo: TStream read fPhoto write fPhoto;
    property PersonType: NullableString read fPersonType write fPersonType;
    property Salary: NullableCurrency read fSalary write fSalary;
    property AnnualBonus: NullableCurrency read fAnnualBonus write fAnnualBonus;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('refresh_demo')]
  TRefreshDemo = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('name', [foRefresh])]
    [MVCMaxLength(200)]
    fName: NullableString;
    [MVCTableField('upper_name', [foReadOnly])]
    fUpperName: NullableString;
  public
    property ID: NullableInt64 read fID write fID;
    property Name: NullableString read fName write fName;
    property UpperName: NullableString read fUpperName write fUpperName;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('soft_delete_demo')]
  TSoftDeleteDemo = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey])]
    [MVCRequired]
    fID: Int32;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('deleted_at')]
    [MVCSoftDeleted]
    fDeletedAt: NullableTDateTime {dtDateTimeStamp};
  public
    property ID: Int32 read fID write fID;
    property Description: NullableString read fDescription write fDescription;
    property DeletedAt: NullableTDateTime {dtDateTimeStamp} read fDeletedAt write fDeletedAt;
  end;

implementation

constructor TPerson.Create;
begin
  inherited Create;
  fPhoto := TMemoryStream.Create;
end;

destructor TPerson.Destroy;
begin
  fPhoto.Free;
  inherited;
end;

initialization

ActiveRecordMappingRegistry.AddEntity('audit_demo', TAuditDemo);
ActiveRecordMappingRegistry.AddEntity('customers', TCustomer);
ActiveRecordMappingRegistry.AddEntity('orders', TOrder);
ActiveRecordMappingRegistry.AddEntity('people', TPerson);
ActiveRecordMappingRegistry.AddEntity('refresh_demo', TRefreshDemo);
ActiveRecordMappingRegistry.AddEntity('soft_delete_demo', TSoftDeleteDemo);

end.