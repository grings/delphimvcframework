unit ex07_filtering;

interface

uses
  MVCFramework.Serializer.Commons,
  MVCFramework.Nullables,
  MVCFramework.ActiveRecord,
  MVCFramework.Validators,
  System.Classes;

type

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers')]
  TCustomers = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
    [MVCTableField('last_contact_timestamp')]
    fLastContactTimestamp: NullableTDateTime {dtDateTimeStampOff};
  public
    property ID: NullableInt64 read fID write fID;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
    property LastContactTimestamp: NullableTDateTime {dtDateTimeStampOff} read fLastContactTimestamp write fLastContactTimestamp;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers_plain')]
  TCustomersPlain = class(TMVCActiveRecord)
  private
    [MVCTableField('id', [foPrimaryKey])]
    [MVCRequired]
    fID: Int64;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
    [MVCTableField('creation_time')]
    fCreationTime: NullableTTime;
    [MVCTableField('creation_date')]
    fCreationDate: NullableTDate;
  public
    property ID: Int64 read fID write fID;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
    property CreationTime: NullableTTime read fCreationTime write fCreationTime;
    property CreationDate: NullableTDate read fCreationDate write fCreationDate;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers_with_code')]
  TCustomersWithCode = class(TMVCActiveRecord)
  private
    [MVCTableField('code', [foPrimaryKey])]
    [MVCRequired]
    [MVCMaxLength(20)]
    fCode: String;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
  public
    property Code: String read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers_with_guid')]
  TCustomersWithGuid = class(TMVCActiveRecord)
  private
    [MVCTableField('idguid', [foPrimaryKey])]
    [MVCRequired]
    fIdguid: TGuid;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
  public
    property Idguid: TGuid read fIdguid write fIdguid;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
  end;

  [MVCNameCase(ncLowerCase)]
  [MVCTable('customers_with_version')]
  TCustomersWithVersion = class(TMVCActiveRecord)
  private
    [MVCTableField('id')]
    [MVCRequired]
    fID: Int64;
    [MVCTableField('code')]
    [MVCMaxLength(20)]
    fCode: NullableString;
    [MVCTableField('description')]
    [MVCMaxLength(200)]
    fDescription: NullableString;
    [MVCTableField('city')]
    [MVCMaxLength(200)]
    fCity: NullableString;
    [MVCTableField('note')]
    fNote: NullableString;
    [MVCTableField('rating')]
    fRating: NullableInt32;
    [MVCTableField('objversion')]
    fObjversion: NullableInt32;
  public
    property ID: Int64 read fID write fID;
    property Code: NullableString read fCode write fCode;
    property Description: NullableString read fDescription write fDescription;
    property City: NullableString read fCity write fCity;
    property Note: NullableString read fNote write fNote;
    property Rating: NullableInt32 read fRating write fRating;
    property Objversion: NullableInt32 read fObjversion write fObjversion;
  end;

implementation

end.