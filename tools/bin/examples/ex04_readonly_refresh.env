# ============================================================================
# Example 04 - foReadOnly + foRefresh (computed columns)
# The refresh_demo table has:
#   name        VARCHAR(200)    - writable column; refreshed after write
#   upper_name  VARCHAR(200) GENERATED ALWAYS AS (UPPER(name)) STORED
#                              - read-only column (must not be written by client)
#
# READONLY_COLUMNS adds foReadOnly and suppresses [MVCRequired]/[MVCMaxLength]
# (validation makes no sense for columns the user cannot write).
# REFRESH_COLUMNS adds foRefresh but keeps [MVCRequired]/[MVCMaxLength].
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex04_readonly_refresh.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
# Default: LowerCase
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
# Default: false
GENERATE_MAPPING=false

# When true, generated classes use a TCustomXxx prefix and are declared
# abstract, allowing you to subclass them and re-generate without overwriting
# your customisations.
# Default: false
CLASS_AS_ABSTRACT=false

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all.
# Default: empty (all tables)
TABLES=refresh_demo

# Comma-separated list of "table.column" pairs that must never be written by
# the ORM (e.g. GENERATED ALWAYS, ROWVERSION, trigger-managed columns).
# Each listed column gets foReadOnly in its [MVCTableField] attribute and is
# excluded from [MVCRequired] and [MVCMaxLength].
# Default: empty (no read-only columns)
READONLY_COLUMNS=refresh_demo.upper_name

# Comma-separated list of "table.column" pairs whose value should be re-read
# from the database after every INSERT or UPDATE (e.g. BEFORE-trigger columns
# that normalise or compute the stored value).
# Each listed column gets foRefresh in its [MVCTableField] attribute.
# Unlike READONLY_COLUMNS, these columns are still writable by the client.
# Default: empty (no refresh columns)
REFRESH_COLUMNS=refresh_demo.name

# Table-to-class name override.
MAP_refresh_demo=TRefreshDemo
