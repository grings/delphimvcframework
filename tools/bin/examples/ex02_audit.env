# ============================================================================
# Example 02 - Auto-Audit columns
# The audit_demo table has created_at, updated_at, created_by, updated_by.
# The generator recognises them by name and type and emits [MVCAudit*].
# These columns do NOT receive [MVCRequired] or [MVCMaxLength] because the
# framework populates them automatically in OnBeforeInsert / OnBeforeUpdate.
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex02_audit.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
# Default: LowerCase
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
# Default: false
GENERATE_MAPPING=false

# When true, generated classes use a TCustomXxx prefix and are declared
# abstract, allowing you to subclass them and re-generate without overwriting
# your customisations.
# Default: false
CLASS_AS_ABSTRACT=false

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all.
# Default: empty (all tables)
TABLES=audit_demo

# When true, columns whose names match the AUDIT_*_NAME values below are
# decorated with the corresponding [MVCAudit*] attribute and excluded from
# [MVCRequired] / [MVCMaxLength] (the framework fills them automatically).
# Default: true
AUTO_AUDIT=true

# Column name recognised as the record creation timestamp ([MVCAuditCreatedAt]).
# The column must be of type TDateTime or NullableTDateTime.
# Default: created_at
AUDIT_CREATED_AT_NAME=created_at

# Column name recognised as the last-update timestamp ([MVCAuditUpdatedAt]).
# The column must be of type TDateTime or NullableTDateTime.
# Default: updated_at
AUDIT_UPDATED_AT_NAME=updated_at

# Column name recognised as the creator identity ([MVCAuditCreatedBy]).
# The column must be of type String or NullableString.
# Default: created_by
AUDIT_CREATED_BY_NAME=created_by

# Column name recognised as the last-updater identity ([MVCAuditUpdatedBy]).
# The column must be of type String or NullableString.
# Default: updated_by
AUDIT_UPDATED_BY_NAME=updated_by

# Table-to-class name override.
MAP_audit_demo=TAuditDemo
