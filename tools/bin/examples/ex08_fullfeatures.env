# ============================================================================
# Example 08 - All features combined
# Demonstrates the full output with auto-required, auto-maxlength, auto-audit,
# auto-soft-delete, read-only / refresh columns, and custom class name mapping.
# ============================================================================

# FireDAC driver identifier. PG = PostgreSQL.
DRIVER_ID=PG

# Database server hostname or IP address.
SERVER=localhost

# Database server port.
PORT=5432

# Name of the target database.
DATABASE=activerecorddb

# Database login username.
USER_NAME=postgres

# Database login password.
PASSWORD=postgres

# Schema to introspect. Leave empty to use the driver default.
SCHEMA=public

# Full path of the generated .pas file.
OUTPUT_FILE=C:\DEV\dmvcframework\tools\bin\examples\ex08_fullfeatures.pas

# Naming convention applied to [MVCNameCase] on every generated class.
# Values: LowerCase | UpperCase | CamelCase | PascalCase | SnakeCase | AsIs
NAME_CASE=LowerCase

# Format used for field variable names inside the class.
# AsIs keeps the database column name as-is; PascalCase converts it to PascalCase.
# Default: PascalCase
FIELD_NAME_FORMAT=PascalCase

# When true, emits an initialization block that registers every entity in
# ActiveRecordMappingRegistry so the ORM can locate the class by table name.
GENERATE_MAPPING=true

# When true, generated classes use a TCustomXxx prefix and are declared
# abstract, allowing you to subclass them and re-generate without overwriting
# your customisations.
CLASS_AS_ABSTRACT=false

# Comma-separated list of tables to generate. Supports exact names, wildcards
# (e.g. orders*), and regex patterns (e.g. /^order_/). Leave empty for all.
TABLES=customers,orders,people,audit_demo,soft_delete_demo,refresh_demo

# Tier 1 - Automatic validation attributes derived from DB schema metadata.

# When true, emits [MVCRequired] on every NOT NULL, non-PK, non-audit column.
# Default: true
AUTO_REQUIRED=true

# When true, emits [MVCMaxLength(N)] on every bounded VARCHAR/CHAR column.
# Default: true
AUTO_MAXLENGTH=true

# Tier 2a - Audit column auto-detection.

# When true, columns matching the AUDIT_*_NAME names below are decorated with
# [MVCAudit*] and excluded from [MVCRequired] / [MVCMaxLength].
# Default: true
AUTO_AUDIT=true

# Column name recognised as the record creation timestamp ([MVCAuditCreatedAt]).
# Default: created_at
AUDIT_CREATED_AT_NAME=created_at

# Column name recognised as the last-update timestamp ([MVCAuditUpdatedAt]).
# Default: updated_at
AUDIT_UPDATED_AT_NAME=updated_at

# Column name recognised as the creator identity ([MVCAuditCreatedBy]).
# Default: created_by
AUDIT_CREATED_BY_NAME=created_by

# Column name recognised as the last-updater identity ([MVCAuditUpdatedBy]).
# Default: updated_by
AUDIT_UPDATED_BY_NAME=updated_by

# Tier 2b - Soft-delete column auto-detection.

# When true, the generator looks for a soft-delete column in each table and
# emits [MVCSoftDeleted] on it. Timestamp mode wins over flag mode.
# Default: true
AUTO_SOFT_DELETE=true

# Comma-separated column names for timestamp-mode soft-delete (NullableTDateTime).
# Default: deleted_at
SOFT_DELETE_TIMESTAMP_NAME=deleted_at

# Comma-separated column names for boolean-flag soft-delete (Boolean).
# Default: is_deleted,deleted
SOFT_DELETE_FLAG_NAME=is_deleted,deleted

# Computed / generated columns.

# Comma-separated "table.column" pairs that must never be written by the ORM.
# Adds foReadOnly to [MVCTableField] and suppresses [MVCRequired]/[MVCMaxLength].
# Default: empty (no read-only columns)
READONLY_COLUMNS=refresh_demo.upper_name

# Comma-separated "table.column" pairs to re-read from the DB after INSERT/UPDATE.
# Adds foRefresh to [MVCTableField]; the column remains writable by the client.
# Default: empty (no refresh columns)
REFRESH_COLUMNS=refresh_demo.name

# Table-to-class name overrides. Tables not listed here get auto-generated names.
MAP_customers=TCustomer
MAP_orders=TOrder
MAP_people=TPerson
MAP_audit_demo=TAuditDemo
MAP_soft_delete_demo=TSoftDeleteDemo
MAP_refresh_demo=TRefreshDemo
